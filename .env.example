# MENUAI - Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# Obrigatorio em producao
JWT_SECRET=sua-chave-secreta-aqui-mude-em-producao

# Obrigatorio em producao (emails separados por virgula)
ADMIN_EMAILS=seu-email@dominio.com

# Porta do servidor (padrao: 3000)
PORT=3000

# Chave da API OpenRouter (opcional - para IA)
OPENROUTER_KEY=